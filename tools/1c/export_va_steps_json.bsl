&НаСервере
Функция СконвертироватьШагVA(ЭлементVA)
	// Helper mapper. Adjust field names once you inspect VA objects in debugger.
	ТекстШага = "";
	Описание = "";
	Путь = "Без раздела";
	Файл = "";
	ИмяПроцедуры = "";

	Если ТипЗнч(ЭлементVA) = Тип("Структура") Тогда
		Если ЭлементVA.Свойство("Шаг") Тогда ТекстШага = Строка(ЭлементVA.Шаг); КонецЕсли;
		Если ЭлементVA.Свойство("Описание") Тогда Описание = Строка(ЭлементVA.Описание); КонецЕсли;
		Если ЭлементVA.Свойство("Путь") Тогда Путь = Строка(ЭлементVA.Путь); КонецЕсли;
		Если ЭлементVA.Свойство("Файл") Тогда Файл = Строка(ЭлементVA.Файл); КонецЕсли;
		Если ЭлементVA.Свойство("Процедура") Тогда ИмяПроцедуры = Строка(ЭлементVA.Процедура); КонецЕсли;
	КонецЕсли;

	Возврат Новый Структура(
		"text,description,path,file,procedure",
		ТекстШага, Описание, Путь, Файл, ИмяПроцедуры
	);
КонецФункции

