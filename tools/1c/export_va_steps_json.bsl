// External processing module template:
// "Export VA Steps to JSON" for Vanessa Automation single/full.
//
// Output format matches VS Code VA Step Library:
// {
//   "version": "1.2.043.1",
//   "generatedAt": "2026-03-04T12:00:00Z",
//   "steps": [
//     {
//       "text": "И я закрываю окно предупреждения",
//       "description": "Закрывает окно предупреждения если оно есть",
//       "path": "UI/Всплывающие окна",
//       "file": "ExternalDataProcessor....",
//       "procedure": "ЯЗакрываюОкноПредупреждения"
//     }
//   ]
// }

&НаКлиенте
Процедура ВыполнитьЭкспорт(Команда)
	ИмяФайла = ПолучитьИмяФайлаЭкспорта();
	Если ПустаяСтрока(ИмяФайла) Тогда
		Возврат;
	КонецЕсли;

	Попытка
		ДанныеДляЭкспорта = СформироватьJSONДанные();
		СтрокаJSON = СериализоватьJSON(ДанныеДляЭкспорта);
		Запись = Новый ЗаписьТекста(ИмяФайла, КодировкаТекста.UTF8);
		Запись.Записать(СтрокаJSON);
		Запись.Закрыть();
		Сообщить("VA библиотека шагов сохранена: " + ИмяФайла);
	Исключение
		ПоказатьПредупреждение("Ошибка экспорта VA шагов: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Функция ПолучитьИмяФайлаЭкспорта()
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = "Сохранить библиотеку шагов VA в JSON";
	Диалог.Фильтр = "JSON (*.json)|*.json";
	Диалог.ПолноеИмяФайла = "va-step-library.json";
	Если Не Диалог.Выбрать() Тогда
		Возврат "";
	КонецЕсли;
	Возврат Диалог.ПолноеИмяФайла;
КонецФункции

&НаСервере
Функция СформироватьJSONДанные()
	Шаги = ПолучитьШагиVA();

	Результат = Новый Структура;
	Результат.Вставить("version", ПолучитьВерсиюVA());
	Результат.Вставить("generatedAt", Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd'T'HH:mm:ss"));
	Результат.Вставить("steps", Шаги);

	Возврат Результат;
КонецФункции

&НаСервере
Функция СериализоватьJSON(Данные)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

&НаСервере
Функция ПолучитьВерсиюVA()
	// Optional: replace with actual VA version getter from your environment.
	Возврат "unknown";
КонецФункции

